{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GradeRule",
  "type": "object",
  "required": [
    "grade",
    "enabled",
    "class_modes",
    "class_subject_groups",
    "constraints",
    "pricing",
    "discounts",
    "quote_validity",
    "ui_hints"
  ],
  "properties": {
    "grade": { "type": "string", "minLength": 1 },
    "enabled": { "type": "boolean" },
    "class_modes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "class_subject_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 1 }
      }
    },
    "discounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "enabled", "strategy", "params", "requires_history_student", "exclusive_with"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "strategy": { "type": "string", "minLength": 1 },
          "params": { "type": "object" },
          "requires_history_student": { "type": "boolean" },
          "exclusive_with": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
